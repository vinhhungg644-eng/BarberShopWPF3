<Window x:Class="BarberShopWPF.Views.AdminView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:BarberShopWPF.Views"
        Title="Quản Trị Hệ Thống BarberShop" Width="1220" Height="750"
        WindowStartupLocation="CenterScreen" Background="{DynamicResource ContentBg}">

    <Window.Resources>
        <Style x:Key="DrawerStyle" TargetType="Border">
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform X="450"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDrawerOpen}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation
                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                    To="0" Duration="0:0:0.3">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation
                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                    To="450" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="Margin" Value="10,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E2A4A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A3B5E"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBg}">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="18,26,18,10">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="40" Height="40" CornerRadius="10" Background="{StaticResource Primary}">
                            <TextBlock Text="✂" FontSize="20" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Foreground="White"/>
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="BARBERSHOP" FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource TextLight}"/>
                            <TextBlock Text="Hệ thống quản lý" FontSize="11"
                                       Foreground="{StaticResource TextMuted}"/>
                        </StackPanel>
                    </StackPanel>
                    <Rectangle Height="1" Fill="{StaticResource BorderSidebar}" Margin="0,18,0,0"/>
                </StackPanel>

                <TextBlock DockPanel.Dock="Top" Text="MENU CHÍNH" FontSize="10" FontWeight="Bold"
                           Foreground="#3D4D6A" Margin="28,12,0,8"/>

                <StackPanel DockPanel.Dock="Top">
                    <RadioButton Content="📊   Dashboard"   GroupName="Menu" Style="{StaticResource NavRadioButtonStyle}" IsChecked="{Binding ShowDash,    Mode=OneWay}" Command="{Binding NavDashCmd}"/>
                    <RadioButton Content="✂   Dịch vụ"      GroupName="Menu" Style="{StaticResource NavRadioButtonStyle}" IsChecked="{Binding ShowSvc,     Mode=OneWay}" Command="{Binding NavSvcCmd}"/>
                    <RadioButton Content="👤   Thợ cắt tóc" GroupName="Menu" Style="{StaticResource NavRadioButtonStyle}" IsChecked="{Binding ShowBarber,  Mode=OneWay}" Command="{Binding NavBarberCmd}"/>
                    <RadioButton Content="🧴   Sản phẩm"     GroupName="Menu" Style="{StaticResource NavRadioButtonStyle}" IsChecked="{Binding ShowProd,    Mode=OneWay}" Command="{Binding NavProdCmd}"/>
                    <RadioButton Content="🎟️   Voucher"      GroupName="Menu" Style="{StaticResource NavRadioButtonStyle}" IsChecked="{Binding ShowVoucher, Mode=OneWay}" Command="{Binding NavVoucherCmd}"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="14,0,14,18">
                    <Rectangle Height="1" Fill="{StaticResource BorderSidebar}" Margin="0,0,0,14"/>
                    <Border CornerRadius="10" Padding="10,8">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1A233A"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="38" Height="38" CornerRadius="19" Background="{StaticResource Primary}">
                                <TextBlock Text="A" FontSize="16" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="White"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding CurrentAccount.FullName}" FontSize="13"
                                           FontWeight="SemiBold" Foreground="{StaticResource TextLight}"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="Quản trị viên" FontSize="11"
                                           Foreground="{StaticResource TextMuted}"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="⏻" Width="32" Height="32" FontSize="16"
                                    Style="{StaticResource BtnGhost}" ToolTip="Đăng xuất"
                                    Command="{Binding LogoutCmd}"/>
                        </Grid>
                    </Border>
                </StackPanel>
                <Grid/>
            </DockPanel>
        </Border>

        <!-- CONTENT -->
        <Grid Grid.Column="1">
            <views:DashboardUC Visibility="{Binding ShowDash,    Converter={StaticResource BoolToVis}}"/>
            <views:ServiceUC   Visibility="{Binding ShowSvc,     Converter={StaticResource BoolToVis}}"/>
            <views:BarberUC    Visibility="{Binding ShowBarber,  Converter={StaticResource BoolToVis}}"/>
            <views:ProductUC   Visibility="{Binding ShowProd,    Converter={StaticResource BoolToVis}}"/>
            <views:VoucherUC   Visibility="{Binding ShowVoucher, Converter={StaticResource BoolToVis}}"/>
        </Grid>

        <!-- DRAWER OVERLAY -->
        <Border Grid.ColumnSpan="2" Background="#66000000"
                Visibility="{Binding IsDrawerOpen, Converter={StaticResource BoolToVis}}"
                Margin="-10,-1,10,0">
            <Border.InputBindings>
                <MouseBinding MouseAction="LeftClick" Command="{Binding CloseDrawerCmd}"/>
            </Border.InputBindings>
        </Border>

        <!-- DRAWER PANEL -->
        <Border Grid.ColumnSpan="2" Width="450" Background="White"
                HorizontalAlignment="Right" Style="{StaticResource DrawerStyle}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" Opacity="0.15" ShadowDepth="-5"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="70"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderLight}">
                    <DockPanel Margin="25,0">
                        <Button Content="✕" Command="{Binding CloseDrawerCmd}"
                                DockPanel.Dock="Right" Style="{StaticResource BtnGhost}" FontSize="18"/>
                        <TextBlock Text="CHI TIẾT DỮ LIỆU" VerticalAlignment="Center"
                                   FontSize="16" FontWeight="Bold"/>
                    </DockPanel>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <Grid Margin="25">

                        <!-- Service Form -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DrawerContent}" Value="ServiceForm">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="Tên dịch vụ *" Foreground="{StaticResource TextGray}" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding EditSvc.ServiceName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TxtBox}" Margin="0,0,0,20"/>
                            <TextBlock Text="Giá tiền (đ) *" Foreground="{StaticResource TextGray}" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding EditSvc.Price, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TxtBox}" Margin="0,0,0,20"/>
                            <TextBlock Text="Thời gian (phút)" Foreground="{StaticResource TextGray}" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding EditSvc.DurationMinutes, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TxtBox}" Margin="0,0,0,30"/>
                            <Button Content="Lưu thông tin dịch vụ" Command="{Binding SaveSvcCmd}" Style="{StaticResource BtnSuccess}"/>
                        </StackPanel>

                        <!-- Barber Form -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DrawerContent}" Value="BarberForm">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="Họ và tên thợ *" Foreground="{StaticResource TextGray}" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding EditBarber.FullName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TxtBox}" Margin="0,0,0,20"/>
                            <TextBlock Text="Số điện thoại" Foreground="{StaticResource TextGray}" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding EditBarber.Phone, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TxtBox}" Margin="0,0,0,20"/>
                            <TextBlock Text="Lương cơ bản (đ)" Foreground="{StaticResource TextGray}" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding EditBarber.BasicSalary, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TxtBox}" Margin="0,0,0,30"/>
                            <Button Content="Lưu thông tin thợ" Command="{Binding SaveBarberCmd}" Style="{StaticResource BtnSuccess}"/>
                        </StackPanel>

                        <!-- Product Form -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DrawerContent}" Value="ProductForm">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="Tên sản phẩm *" Foreground="{StaticResource TextGray}" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding EditProd.ProductName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TxtBox}" Margin="0,0,0,20"/>
                            <TextBlock Text="Giá bán (đ) *" Foreground="{StaticResource TextGray}" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding EditProd.Price, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TxtBox}" Margin="0,0,0,20"/>
                            <TextBlock Text="Số lượng tồn kho" Foreground="{StaticResource TextGray}" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding EditProd.Stock, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TxtBox}" Margin="0,0,0,30"/>
                            <Button Content="Lưu thông tin sản phẩm" Command="{Binding SaveProdCmd}" Style="{StaticResource BtnSuccess}"/>
                        </StackPanel>

                        <!-- Voucher Form -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DrawerContent}" Value="VoucherForm">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="MÃ VOUCHER *" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMuted}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding EditVoucher.Code, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource TxtBox}" Margin="0,0,0,18" CharacterCasing="Upper"/>
                            <TextBlock Text="MÔ TẢ (tùy chọn)" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMuted}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding EditVoucher.Description, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource TxtBox}" Margin="0,0,0,18"/>
                            <TextBlock Text="SỐ TIỀN GIẢM (đ) *" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMuted}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding EditVoucher.DiscountAmount, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource TxtBox}" Margin="0,0,0,18"/>
                            <TextBlock Text="HẠN SỬ DỤNG" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMuted}" Margin="0,0,0,6"/>
                            <DatePicker SelectedDate="{Binding EditVoucher.ExpiryDate}"
                                        Height="42" FontSize="13"
                                        BorderBrush="{StaticResource BorderLight}" Margin="0,0,0,18"/>
                            <TextBlock Text="GIỚI HẠN SỐ LẦN DÙNG (để trống = không giới hạn)"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMuted}" Margin="0,0,0,6" TextWrapping="Wrap"/>
                            <TextBox Text="{Binding EditVoucher.MaxUsage, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                     Style="{StaticResource TxtBox}" Margin="0,0,0,18"/>
                            <CheckBox Content="Kích hoạt ngay" IsChecked="{Binding EditVoucher.IsActive}"
                                      Foreground="{StaticResource TextDark}" FontSize="13" Margin="0,0,0,28"/>
                            <Button Content="💾  Lưu Voucher" Command="{Binding SaveVoucherCmd}"
                                    Style="{StaticResource BtnSuccess}" Height="44"/>
                        </StackPanel>

                        <!-- FreeBarberList -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DrawerContent}" Value="FreeBarberList">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="Thợ đang ngồi chờ khách" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
                            <DataGrid ItemsSource="{Binding DashboardFreeBarberList}" AutoGenerateColumns="False"
                                      IsReadOnly="True" HeadersVisibility="None">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Binding="{Binding FullName}" Width="*"/>
                                    <DataGridTextColumn Binding="{Binding Phone}" Width="120"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>

                        <!-- CustomerList -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DrawerContent}" Value="CustomerList">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="Khách hàng hoàn thành" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
                            <DataGrid ItemsSource="{Binding DashboardCustomerList}" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Khách"   Binding="{Binding Name}"    Width="110"/>
                                    <DataGridTextColumn Header="Dịch vụ" Binding="{Binding Service}" Width="*"/>
                                    <DataGridTextColumn Header="Giờ"     Binding="{Binding Time}"    Width="50"/>
                                    <DataGridTextColumn Header="Tiền"    Binding="{Binding Price}"   Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>

                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
