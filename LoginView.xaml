<Window x:Class="BarberShopWPF.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BarberShopWPF.ViewModels"
        Title="BarberShop - Đăng nhập"
        Width="900" Height="580"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

	<Window.DataContext>
		<vm:LoginViewModel/>
	</Window.DataContext>

	<!-- Root border tạo rounded corner cho toàn window -->
	<Border CornerRadius="16" ClipToBounds="True">
		<Grid>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="2*"/>
				<ColumnDefinition Width="3*"/>
			</Grid.ColumnDefinitions>

			<!-- ═══════ CỘT TRÁI – BRAND ═══════ -->
			<Border Grid.Column="0" Background="{StaticResource SidebarBg}">
				<Grid>
					<!-- Decoration -->
					<Ellipse Width="320" Height="320"
                             HorizontalAlignment="Center" VerticalAlignment="Top"
                             Margin="0,71,0,0" Opacity="0.12">
						<Ellipse.Fill>
							<SolidColorBrush Color="#6C63FF"/>
						</Ellipse.Fill>
					</Ellipse>
					<Ellipse Width="200" Height="200"
                             HorizontalAlignment="Right" VerticalAlignment="Bottom"
                             Margin="0,0,-70,-70" Opacity="0.08">
						<Ellipse.Fill>
							<SolidColorBrush Color="#6C63FF"/>
						</Ellipse.Fill>
					</Ellipse>

					<StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Margin="30,0">
						<!-- Logo -->
						<Border Width="72" Height="72" CornerRadius="36"
                                Background="{StaticResource Primary}"
                                HorizontalAlignment="Center" Margin="0,0,0,18">
							<TextBlock Text="✂" FontSize="34"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="White"/>
						</Border>

						<TextBlock Text="BARBER SHOP"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource TextLight}"
                                   HorizontalAlignment="Center"/>

						<TextBlock Text="Hệ thống quản lý tiệm cắt tóc"
                                   FontSize="12" Foreground="{StaticResource TextMuted}"
                                   HorizontalAlignment="Center" TextAlignment="Center"
                                   TextWrapping="Wrap" Margin="0,8,0,0"/>

						<Rectangle Height="1" Fill="#2A3A5A" Margin="0,28,0,20"/>

						<!-- Features -->
						<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
							<Ellipse Width="8" Height="8" Fill="{StaticResource Green}"
                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
							<TextBlock Text="Admin Dashboard" Foreground="{StaticResource TextMuted}" FontSize="12"/>
						</StackPanel>
						<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
							<Ellipse Width="8" Height="8" Fill="{StaticResource Orange}"
                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
							<TextBlock Text="Quản lý lịch hẹn" Foreground="{StaticResource TextMuted}" FontSize="12"/>
						</StackPanel>
						<StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
							<Ellipse Width="8" Height="8" Fill="{StaticResource Primary}"
                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
							<TextBlock Text="Đặt lịch trực tuyến" Foreground="{StaticResource TextMuted}" FontSize="12"/>
						</StackPanel>
					</StackPanel>
				</Grid>
			</Border>

			<!-- ═══════ CỘT PHẢI – FORM ═══════ -->
			<Border Grid.Column="1" Background="{StaticResource DarkBg}">
				<Grid>
					<!-- Nút đóng -->
					<Button Content="✕" Width="32" Height="32"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,14,18,0"
                            Style="{StaticResource BtnGhost}" FontSize="16"
                            Click="CloseBtn_Click"/>

					<!-- Form -->
					<StackPanel VerticalAlignment="Center" Margin="60,0">
						<TextBlock Text="Chào mừng trở lại 👋"
                                   FontSize="30" FontWeight="Bold"
                                   Foreground="{StaticResource TextLight}"
                                   Margin="0,0,0,6"/>
						<TextBlock Text="Đăng nhập "
                                   FontSize="13" Foreground="{StaticResource TextMuted}"
                                   Margin="0,0,0,34"/>

						<!-- Username -->
						<TextBlock Text="TÊN ĐĂNG NHẬP" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMuted}" Margin="0,0,0,8"/>
						<TextBox Style="{StaticResource TxtBoxDark}"
                                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 x:Name="TxtUser"/>

						<!-- Password -->
						<TextBlock Text="MẬT KHẨU" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMuted}" Margin="0,20,0,8"/>
						<PasswordBox x:Name="PbPwd"
                                     Style="{StaticResource PwdBoxDark}"
                                     KeyDown="PbPwd_KeyDown"/>

						<!-- Error message -->
						<Border Background="#1A0A10" CornerRadius="8" Padding="12,8"
                                Margin="0,14,0,0"
                                Visibility="{Binding ErrorMsg, Converter={StaticResource StrToVis}}">
							<TextBlock Text="{Binding ErrorMsg}"
                                       Foreground="{StaticResource ErrorRed}"
                                       FontSize="12" TextWrapping="Wrap"/>
						</Border>

						<!-- Login button -->
						<Button Content="ĐĂNG NHẬP"
                                Style="{StaticResource BtnPrimary}"
                                Height="62" FontSize="14"
                                Margin="0,24,0,0"
                                Click="LoginBtn_Click"/>

						<!-- Register link -->
						<StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center" Margin="0,22,0,0">
							<TextBlock Text="Chưa có tài khoản?  "
                                       Foreground="{StaticResource TextMuted}" FontSize="12"/>
							<TextBlock Text="Đăng ký ngay"
                                       Foreground="{StaticResource Primary}"
                                       FontSize="12" FontWeight="SemiBold"
                                       Cursor="Hand"
                                       MouseLeftButtonUp="RegisterLink_Click"/>
						</StackPanel>
					</StackPanel>
				</Grid>
			</Border>
		</Grid>
	</Border>
</Window>
