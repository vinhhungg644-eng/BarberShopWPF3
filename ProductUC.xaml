<UserControl x:Class="BarberShopWPF.Views.ProductUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<DockPanel Margin="30">
		<Grid DockPanel.Dock="Top" Margin="0,0,0,20">
			<TextBlock Text="Danh sách sản phẩm" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
			<Button Content="+ Thêm mới sản phẩm" Style="{StaticResource BtnPrimary}" HorizontalAlignment="Right" Command="{Binding OpenDrawerCmd}" CommandParameter="ProductForm"/>
		</Grid>
		<DataGrid ItemsSource="{Binding Products}" AutoGenerateColumns="False" IsReadOnly="True">
			<DataGrid.Columns>
				<DataGridTextColumn Header="Tên sản phẩm" Binding="{Binding ProductName}" Width="*"/>
				<DataGridTextColumn Header="Giá bán" Binding="{Binding Price, StringFormat={}{0:N0} đ}" Width="150"/>
				<DataGridTextColumn Header="Tồn kho" Binding="{Binding Stock}" Width="100"/>
				<DataGridTemplateColumn Header="Thao tác" Width="100">
					<DataGridTemplateColumn.CellTemplate>
						<DataTemplate>
							<StackPanel Orientation="Horizontal" x:Name="ActionPanel" Opacity="0.1" HorizontalAlignment="Center">
								<Button Content="✏️" ToolTip="Sửa" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0" Command="{Binding DataContext.EditProdCmd, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
								<Button Content="🗑️" ToolTip="Xóa" Background="Transparent" BorderThickness="0" Cursor="Hand" Command="{Binding DataContext.DelProdCmd, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
							</StackPanel>
							<DataTemplate.Triggers>
								<DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
									<Setter TargetName="ActionPanel" Property="Opacity" Value="1"/>
								</DataTrigger>
							</DataTemplate.Triggers>
						</DataTemplate>
					</DataGridTemplateColumn.CellTemplate>
				</DataGridTemplateColumn>
			</DataGrid.Columns>
		</DataGrid>
	</DockPanel>
</UserControl>