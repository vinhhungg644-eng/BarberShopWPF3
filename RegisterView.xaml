<Window x:Class="BarberShopWPF.Views.RegisterView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng ký tài khoản"
        Width="460" Height="580"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="16" Background="{StaticResource DarkBg}"
            BorderBrush="{StaticResource Primary}" BorderThickness="1.5">
        <StackPanel Margin="40,30">

            <!-- Header -->
            <Grid Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Tạo tài khoản mới"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextLight}"/>
                    <TextBlock Text="Điền thông tin để đăng ký khách hàng"
                               FontSize="12" Foreground="{StaticResource TextMuted}"
                               Margin="0,4,0,0"/>
                </StackPanel>
                <Button Content="✕" Width="30" Height="30"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Style="{StaticResource BtnGhost}" FontSize="15"
                        Click="CloseBtn_Click"/>
            </Grid>

            <!-- FullName -->
            <TextBlock Text="HỌ VÀ TÊN" FontSize="10" FontWeight="SemiBold"
                       Foreground="{StaticResource TextMuted}" Margin="0,0,0,6"/>
            <TextBox x:Name="TxtName" Style="{StaticResource TxtBoxDark}"/>

            <!-- Phone -->
            <TextBlock Text="SỐ ĐIỆN THOẠI" FontSize="10" FontWeight="SemiBold"
                       Foreground="{StaticResource TextMuted}" Margin="0,16,0,6"/>
            <TextBox x:Name="TxtPhone" Style="{StaticResource TxtBoxDark}"/>

            <!-- Username -->
            <TextBlock Text="TÊN ĐĂNG NHẬP" FontSize="10" FontWeight="SemiBold"
                       Foreground="{StaticResource TextMuted}" Margin="0,16,0,6"/>
            <TextBox x:Name="TxtUser" Style="{StaticResource TxtBoxDark}"/>

            <!-- Password -->
            <TextBlock Text="MẬT KHẨU" FontSize="10" FontWeight="SemiBold"
                       Foreground="{StaticResource TextMuted}" Margin="0,16,0,6"/>
            <PasswordBox x:Name="PbPwd" Style="{StaticResource PwdBoxDark}"/>

            <!-- DOB -->
			<TextBlock Text="NGÀY SINH (tùy chọn)" FontSize="10" FontWeight="SemiBold"
           Foreground="{StaticResource TextMuted}" Margin="0,16,0,6"/>
			<DatePicker x:Name="DpDob" Height="42" FontSize="13"
						Background="{StaticResource InputBg}"
						Foreground="Black"
						BorderBrush="{StaticResource InputBorder}">
				<DatePicker.Resources>
					<Style TargetType="DatePickerTextBox">
						<Setter Property="Control.Template">
							<Setter.Value>
								<ControlTemplate>
									<TextBox x:Name="PART_TextBox"
											 Focusable="False"
											 IsReadOnly="True"
											 VerticalContentAlignment="Center"
											 Padding="10,0,0,0"
											 Background="White"
											 Foreground="Black"
											 FontWeight="SemiBold"
											 BorderThickness="0"
											 Text="{Binding Path=SelectedDate, StringFormat='dd/MM/yyyy', RelativeSource={RelativeSource AncestorType=DatePicker}}"/>
								</ControlTemplate>
							</Setter.Value>
						</Setter>
					</Style>
				</DatePicker.Resources>
			</DatePicker>

            <!-- Message -->
            <Border x:Name="MsgBorder" CornerRadius="8" Padding="12,8"
                    Margin="0,14,0,0" Visibility="Collapsed">
                <TextBlock x:Name="TxtMsg" FontSize="12" TextWrapping="Wrap"/>
            </Border>

            <!-- Submit -->
            <Button Content="TẠO TÀI KHOẢN"
                    Style="{StaticResource BtnPrimary}"
                    Height="46" Margin="0,20,0,0"
                    Click="RegisterBtn_Click"/>
        </StackPanel>
    </Border>
</Window>
