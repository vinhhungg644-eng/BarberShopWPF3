<UserControl x:Class="BarberShopWPF.Views.ServiceUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="30">

        <!-- Header -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Quản lý Dịch vụ" FontSize="24" FontWeight="Bold"
                           Foreground="{StaticResource TextDark}"/>
                <TextBlock Text="Thêm, sửa, xóa các dịch vụ của tiệm"
                           FontSize="13" Foreground="{StaticResource TextGray}" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Content="+ Thêm dịch vụ mới"
                    Style="{StaticResource BtnPrimary}"
                    HorizontalAlignment="Right"
                    Command="{Binding OpenDrawerCmd}"
                    CommandParameter="ServiceForm"/>
        </Grid>

        <!-- DataGrid -->
        <DataGrid ItemsSource="{Binding Services}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Tên dịch vụ"   Binding="{Binding ServiceName}"      Width="*"/>
                <DataGridTextColumn Header="Giá (đ)"       Binding="{Binding Price, StringFormat={}{0:N0} đ}" Width="150"/>
                <DataGridTextColumn Header="Thời gian (phút)" Binding="{Binding DurationMinutes}" Width="150"/>
                <DataGridTemplateColumn Header="Thao tác" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" x:Name="ActionPanel"
                                        Opacity="0.1" HorizontalAlignment="Center">
                                <Button Content="✏️" ToolTip="Sửa"
                                        Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" Margin="0,0,10,0"
                                        Command="{Binding DataContext.EditSvcCmd,
                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"/>
                                <Button Content="🗑️" ToolTip="Xóa"
                                        Background="Transparent" BorderThickness="0"
                                        Cursor="Hand"
                                        Command="{Binding DataContext.DelSvcCmd,
                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"/>
                            </StackPanel>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsMouseOver,
                                             RelativeSource={RelativeSource AncestorType=DataGridRow}}"
                                             Value="True">
                                    <Setter TargetName="ActionPanel" Property="Opacity" Value="1"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
