<UserControl x:Class="BarberShopWPF.Views.VoucherUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="30">

        <!-- Header -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Quản lý Voucher" FontSize="24" FontWeight="Bold"
                           Foreground="{StaticResource TextDark}"/>
                <TextBlock Text="Tạo và quản lý mã giảm giá tiền cố định cho khách hàng"
                           FontSize="13" Foreground="{StaticResource TextGray}" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Content="+ Tạo voucher mới"
                    Style="{StaticResource BtnPrimary}"
                    HorizontalAlignment="Right"
                    Command="{Binding OpenDrawerCmd}"
                    CommandParameter="VoucherForm"/>
        </Grid>

        <!-- DataGrid -->
        <DataGrid ItemsSource="{Binding Vouchers}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column">
            <DataGrid.Columns>

                <!-- Mã voucher -->
                <DataGridTemplateColumn Header="Mã Voucher" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="#EEF2FF" CornerRadius="6" Padding="10,4" Margin="6,4" HorizontalAlignment="Left">
                                <TextBlock Text="{Binding Code}" FontWeight="Bold"
                                           Foreground="{StaticResource Primary}" FontSize="13"
                                           FontFamily="Consolas"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Mô tả -->
                <DataGridTextColumn Header="Mô tả" Binding="{Binding Description}" Width="*"/>

                <!-- Giảm giá -->
                <DataGridTemplateColumn Header="Giảm giá (đ)" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DiscountAmount, StringFormat={}{0:N0} đ}"
                                       FontWeight="Bold" Foreground="{StaticResource Orange}"
                                       FontSize="14" Margin="16,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Hạn sử dụng -->
                <DataGridTextColumn Header="Hạn dùng"
                                    Binding="{Binding ExpiryDate, StringFormat='dd/MM/yyyy'}"
                                    Width="110"/>

                <!-- Lượt dùng -->
                <DataGridTemplateColumn Header="Đã dùng / Giới hạn" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="16,0">
                                <TextBlock Text="{Binding UsedCount}" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextDark}"/>
                                <TextBlock Foreground="{StaticResource TextGray}" Margin="4,0">
                                    <TextBlock.Text>
                                        <Binding Path="MaxUsage" StringFormat=" / {0}" FallbackValue=" / ∞"/>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Trạng thái + nút bật/tắt nhanh -->
                <DataGridTemplateColumn Header="Trạng thái" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Margin="8,6" Cursor="Hand" BorderThickness="0"
                                    Command="{Binding DataContext.ToggleVoucherCmd, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd" CornerRadius="12" Padding="10,4" Background="#E8F5E9">
                                                        <TextBlock x:Name="Txt" Text="✅ Đang bật"
                                                                   FontSize="11" FontWeight="SemiBold"
                                                                   Foreground="#2E7D32"
                                                                   HorizontalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                            <Setter TargetName="Bd"  Property="Background" Value="#FFEBEE"/>
                                                            <Setter TargetName="Txt" Property="Text"       Value="⛔ Đã tắt"/>
                                                            <Setter TargetName="Txt" Property="Foreground" Value="#C62828"/>
                                                        </DataTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Thao tác -->
                <DataGridTemplateColumn Header="Thao tác" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" x:Name="ActionPanel"
                                        Opacity="0.1" HorizontalAlignment="Center">
                                <Button Content="✏️" ToolTip="Sửa"
                                        Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" Margin="0,0,10,0"
                                        Command="{Binding DataContext.EditVoucherCmd, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"/>
                                <Button Content="🗑️" ToolTip="Xóa"
                                        Background="Transparent" BorderThickness="0"
                                        Cursor="Hand"
                                        Command="{Binding DataContext.DelVoucherCmd, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"/>
                            </StackPanel>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                    <Setter TargetName="ActionPanel" Property="Opacity" Value="1"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
